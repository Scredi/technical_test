    "express": "^4.21.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "eslint": "^9.13.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2"
  }
}
